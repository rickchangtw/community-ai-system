# ============================================================================
# Community Management System - Environment Variables
# ============================================================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=community
DB_USER=hermes
DB_PASSWORD=hermes123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Line Bot (required for LINE webhook)
LINE_WEBHOOK_SECRET=your_webhook_secret_here
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Agent Authentication (JWT)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=3600

# Health Check
HEALTH_CHECK_PORT=3000
